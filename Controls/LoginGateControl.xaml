<UserControl x:Class="BariPluxTool.Controls.LoginGateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             IsHitTestVisible="True"
             Focusable="True">
    <Grid Background="#D9020617">
        <Border Width="400"
                Margin="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="16"
                BorderBrush="#334155"
                BorderThickness="1"
                Background="#0F172A"
                Padding="28,26">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{DynamicResource SignInToBariPlux}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F1F5F9"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource SignInBrowserDesc}"
                           FontSize="12"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,22"/>

                <Button x:Name="BtnOpenBrowser"
                        Click="BtnOpenBrowser_Click"
                        Cursor="Hand"
                        Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBg"
                                    CornerRadius="10"
                                    Background="#6C63FF"
                                    Padding="16,12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE774;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource OpenSignInBrowser}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBg" Property="Background" Value="#5B4FE8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock x:Name="StatusText"
                           Text="{DynamicResource WaitingForSignIn}"
                           FontSize="11"
                           Foreground="#64748B"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,18"/>

                <Button x:Name="BtnSkipLogin"
                        Content="{DynamicResource ContinueWithoutAccount}"
                        Click="BtnSkipLogin_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#64748B"
                        FontSize="11"
                        Cursor="Hand"
                        Padding="4"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
