{
  "rules": {
    "admin": {
      ".read": "auth != null && auth.uid === 'ZHMxN5tZkNgLcxFnp98QUqfvw963'",
      ".write": "auth != null && auth.uid === 'ZHMxN5tZkNgLcxFnp98QUqfvw963'"
    },
    "app_config": {
      ".read": true,
      ".write": false
    },
    "users": {
      ".read": "auth.uid === 'ZHMxN5tZkNgLcxFnp98QUqfvw963'",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid",
        "role": {
          ".validate": "newData.isString() && newData.val() matches /^(user|admin|developer|moderator)$/"
        }
      }
    },
    "discordUsers": {
      ".read": "auth != null && auth.uid === 'o2hD76smAygVFJlO3Uu8jDdcatW2'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "sessions": {
      "$uid": {
        "$sessionId": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      }
    },
    "pending_tokens": {
      "$uid": {
        "$sessionId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "bugReports": {
      ".read": "auth.uid === 'ZHMxN5tZkNgLcxFnp98QUqfvw963' || root.child('users/' + auth.uid + '/role').val() === 'admin'",
      ".write": "auth.uid === 'ZHMxN5tZkNgLcxFnp98QUqfvw963' || root.child('users/' + auth.uid + '/role').val() === 'admin'",
      ".indexOn": ["status", "timestamp"]
    },
    "serverTime": {
      ".read": true,
      ".write": false
    }
  }
}
